#version 330 core
  in vec2 fragCoord;
  out vec4 FragColor;

  uniform float uAlpha;
  uniform float uBeta;

  void main() {
    float psi = fragCoord.x * 3.0;
    float psi2 = psi * psi;
    float U = uAlpha * psi2 + uBeta * (psi2 * psi2);

    float curveY = U * 0.15;
    float dist = abs(fragCoord.y - curveY);
    float line = smoothstep(0.05, 0.0, dist);

    float t = clamp(uAlpha * 0.5 + 0.5, 0.0, 1.0);
    vec3 coldColor = vec3(0.2, 0.6, 1.0);
    vec3 hotColor = vec3(1.0,0.6,0.1);
    vec3 curveColor = mix(coldColor, hotColor, t);

    vec3 color = mix(vec3(0.08), curveColor, line);

    float axisX = smoothstep(0.008, 0.0, abs(fragCoord.x));
    float axisY = smoothstep(0.008, 0.0, abs(fragCoord.y));
    float axes  = max(axisX, axisY);

    vec3 axisColor = vec3(0.4);
    color = mix(color, axisColor, axes);

    float minima = 0.0;
    if (uAlpha < 0.0) {
      float psiMin = sqrt(-uAlpha / (2.0 * uBeta));
      float vMin = uAlpha * psiMin*psiMin + uBeta * psiMin*psiMin*psiMin*psiMin;
      float xMin = psiMin / 3.0;
      float yMin = vMin * 0.15;

      float d1 = length(fragCoord - vec2(xMin, yMin));
      float d2 = length(fragCoord - vec2(-xMin, yMin));
      minima = smoothstep(0.03, 0.0, d1) + smoothstep(0.03, 0.0, d2);
    }
    color = mix(color, vec3(0.2, 1.0, 0.5), clamp(minima, 0.0, 1.0));

    FragColor = vec4(color, 1.0);
  }
